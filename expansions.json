      "text" : {
        "status" : "generated",
        "div" : "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>This value set contains 45 concepts</p><div style=\"border: black 1px dotted; background-color: #EEEEEE; padding: 8px; margin-bottom: 8px\"><p>Expansion based on: </p><ul><li><a href=\"CodeSystem-IPLOStjenestetyper2019CS.html\">IPLOS tjenestetyper 2019 (subsett) v0.1.0 (CodeSystem)</a></li><li><a href=\"CodeSystem-carerelation.html\">DIPS care relation code system v0.1.0 (CodeSystem)</a></li></ul></div><table class=\"codes\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>System</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-HENV-BEH\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-HENV_BEH\">HENV_BEH</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Henvendelse fra pasientens behandler</td><td><div><p>Henvendelse fra pasientens behandler.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-HENV-PAA\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-HENV_PAA\">HENV_PAA</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Henvendelse fra pasientens pårørende</td><td><div><p>Henvendelse fra pasientens pårørende.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-MELDT\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-MELDT\">MELDT</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Meldt pasient</td><td><div><p>Meldt pasient (for eksempel fra legevakta eller ambulansen).</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-BLAALYS\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-BLAALYS\">BLAALYS</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Blålys</td><td><div><p>Bruk av blålys - akutt helsehjelp</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-EKSTSVAR\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-EKSTSVAR\">EKSTSVAR</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Eksternt prøvesvar/notat til vurdering</td><td><div><p>Det er behov for å se på et eksternt prøvesvar eller notat som har kommet inn på pasienten</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-KVAL\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-KVAL\">KVAL</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Internkontroll/Kvalitetssikring</td><td><div><p>Noen ansatte har som oppgave å kontrollere koder og andre registreringer i DIPS, kanskje også se på hvordan det registreres/dokumenteres m.m uten at brukeren deltar i behandling av pasient.   Da kan denne beslutningsmalen brukes.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-OPRPLAN\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-OPRPLAN\">OPRPLAN</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Pasienten finnes på operasjonsoversikten</td><td><div><p>Pasienten finnes på operasjonsoversikten i DIPS</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-KONSSERIE\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-KONSSERIE\">KONSSERIE</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Åpen konsultasjonsserie</td><td><div><p>Åpen konsultasjonsserie</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-LEDSBEL\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-LEDSBEL\">LEDSBEL</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Inneliggende ledsager</td><td><div><p>Ledsageren er inneliggende.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-VURDHENV\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-VURDHENV\">VURDHENV</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Vurdert henvisning</td><td><div><p>Henvisning som er vurdert</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-ITSYSARB\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-ITSYSARB\">ITSYSARB</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>IT-Systemarbeid</td><td><div><p>IT systemarbeid er en besluttningsmal som kan benyttes for å gi tilgang til journaldata når it-personell (på sykehuset / eller personell fra DIPS ASA), må gjøre systemarbeid - feilretting o.l. - på journaldataene.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-TILSYN\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-TILSYN\">TILSYN</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Tilsyn på annen avdeling.</td><td><div><p>&quot;Tilsyn på annen avdeling&quot; kan benyttes når en behandler bes om å foreta et tilsyn på en annen avdeling, og behandleren av den grunn ikke har ordinær tilgang til journalen.  Det kan angis hvilken rekvirent som har bedt om at tilsyn skal foretas.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-ARBFLYT\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-ARBFLYT\">ARBFLYT</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Oppgave i arbeidsflyt</td><td><div><p>Beslutning som slår til dersom det finnes en ikke utført oppgave i arbeidsflyt.  Gjelder alle oppgavetyper.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-BEHANDLER\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-BEHANDLER\">BEHANDLER</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Bruker har behandlingsansvar for pasienten</td><td><div><p>Brukeren er behandler for pasienten. Eksempler på hva som gjør at malen slår til er:\na) Bruker er registrert som ansvarlig behandler på poliklinisk besøk.\nb) Bruker er registrert som behandler på planlagt kontakt.\nc) Bruker er registrert som ansvarlig lege på et postopphold.\nd) Bruker er registrert som ansvarlig behandler for omsorgsserie i psykiatrien.\ne) Bruker er registrert som koterapeut til en poliklinisk konsultasjon (gjelder psykiatri).\nf) Bruker er registrert som deltaker (ressurs) i en planlagt aktivitet i pasientens timebok.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-INFOANSV\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-INFOANSV\">INFOANSV</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Bruker er informasjonsansvarlig for pasienten</td><td><div><p>Brukeren er informasjonsansvarlig for pasienten.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-JOURANSV\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-JOURANSV\">JOURANSV</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Bruker er journalansvarlig for pasienten</td><td><div><p>Brukeren er journalansvarlig for pasienten.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-PASANSV\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-PASANSV\">PASANSV</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Bruker er koordinator for pasienten</td><td><div><p>Brukeren er koordinator for pasienten.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-HENVISNING\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-HENVISNING\">HENVISNING</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Henvisning til vurdering</td><td><div><p>Henvisning som enda ikke er vurdert.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-BELEGG\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-BELEGG\">BELEGG</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Inneliggende pasient</td><td><div><p>Pasienten er inneliggende.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-PLANOPP\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-PLANOPP\">PLANOPP</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Planlagt oppmøte</td><td><div><p>Planlagt oppmøte for pasienten.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-POLBESOK\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-POLBESOK\">POLBESOK</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Poliklinisk besøk</td><td><div><p>Poliklinisk konsultasjon.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-TILSYN2\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-TILSYN2\">TILSYN2</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Tilsyn med helsepersonellets virksomhet</td><td><div><p>Tilsyn med helsepersonellets virksomhet.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-INNSYN\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-INNSYN\">INNSYN</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Pasientinnsyn</td><td><div><p>Pasientens innsyn i egen journal.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-OFFBEST\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-OFFBEST\">OFFBEST</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Bestilling av dokumenter fra offentlige og juridiske instanser og forsikringselskap</td><td><div><p>Bestilling av dokumenter fra offentlige og juridiske instanser og forsikringselskap.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-HENV-PAS\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-HENV_PAS\">HENV_PAS</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Henvendelse fra pasienten</td><td><div><p>Henvendelse fra pasienten selv.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-HENVPER\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-HENVPER\">HENVPER</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Åpen henvisningsperiode</td><td><div><p>Åpen henvisningsperiode.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-PLANKONT\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-PLANKONT\">PLANKONT</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Ventende pasient</td><td><div><p>Pasienten har en planlagt kontakt som ikke er avsluttet.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-PRIMKONT\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-PRIMKONT\">PRIMKONT</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Bruker er pasientens primærkontakt</td><td><div><p>Bruker er pasientens primærkontakt.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-DELBEHAN\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-DELBEHAN\">DELBEHAN</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Deltar i behandlingen av pasienten</td><td><div><p>Deltar i behandlingen av pasienten.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-TILSYN3\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-TILSYN3\">TILSYN3</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Statlig tilsyn</td><td><div><p>Statlig tilsyn er forankret i  Helsetilsynsloven, Spesialisthelsetjenesteloven §6-2 og Pasientjournalloven §26.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-HHJELANPAS\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-HHJELANPAS\">HHJELANPAS</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Yte helsehjelp til annen pasient</td><td><div><p>&quot;Yte helsehjelp til annen pasient&quot; kan benyttes for å gi tilgang til pasientopplysninger på en pasient for å yte helsehjelp til annen pasient, jf. helsepersonelloven §25 b.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-NYPAS\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-NYPAS\">NYPAS</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Pasientadministrasjon</td><td><div><p>Pasientadministrasjon, f.eks registrering av ny pasient</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-ROLPAS\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-ROLPAS\">ROLPAS</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Bruker har rolle overfor pasient</td><td><div><p>Bruker har rolle overfor pasient</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-carerelation-EGENLAER\"> </a>  <a href=\"CodeSystem-carerelation.html#carerelation-EGENLAER\">EGENLAER</a></td><td>urn:AuditEventHL7Norway/CodeSystem/carerelation</td><td>Egen læring/kvalitetssikring av gitt behandling</td><td><div><p>Begrunnelse forankret i Helsepersonellovens §29 c</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-IPLOStjenestetyper2019CS-07\"> </a>  <a href=\"CodeSystem-IPLOStjenestetyper2019CS.html#IPLOStjenestetyper2019CS-07\">07</a></td><td>urn:AuditEventHL7Norway/CodeSystem/IPLOStjenestetyper2019CS</td><td>Avlastning - utenfor institusjon</td><td><div></div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-IPLOStjenestetyper2019CS-08\"> </a>  <a href=\"CodeSystem-IPLOStjenestetyper2019CS.html#IPLOStjenestetyper2019CS-08\">08</a></td><td>urn:AuditEventHL7Norway/CodeSystem/IPLOStjenestetyper2019CS</td><td>Avlastning - i institusjon</td><td><div></div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-IPLOStjenestetyper2019CS-08.01\"> </a>  <a href=\"CodeSystem-IPLOStjenestetyper2019CS.html#IPLOStjenestetyper2019CS-08.4601\">08.01</a></td><td>urn:AuditEventHL7Norway/CodeSystem/IPLOStjenestetyper2019CS</td><td>Avlastning i institusjon - rullerende</td><td><div></div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-IPLOStjenestetyper2019CS-08.02\"> </a>  <a href=\"CodeSystem-IPLOStjenestetyper2019CS.html#IPLOStjenestetyper2019CS-08.4602\">08.02</a></td><td>urn:AuditEventHL7Norway/CodeSystem/IPLOStjenestetyper2019CS</td><td>Avlastning i institusjon - ikke rullerende</td><td><div></div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn-AuditEventHL7Norway-CodeSystem-IPLOStjenestetyper2019CS-15\"> </a>  <a href=\"CodeSystem-IPLOStjenestetyper2019CS.html#IPLOStjenestetyper2019CS-15\">15</a></td><td>urn:AuditEventHL7Norway/CodeSystem/IPLOStjenestetyper2019CS</td><td>Helsetjenester i hjemmet</td><td><div></div></td></tr><tr><td style=\"white-space:nowrap\"><a name=\"urn