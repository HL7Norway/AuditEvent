       fhir:system [ fhir:v "http://terminology.hl7.org/CodeSystem/security-source-type"^^xsd:anyURI ] ;
       fhir:code [ fhir:v "4" ] ;
       fhir:display [ fhir:v "Application Server" ]
     ] )
  ] ; # 
  fhir:entity ( [
     fhir:what [
       fhir:link <urn:no-basis-auditevent/StructureDefinition/DocumentReference> ;
       fhir:reference [ fhir:v "StructureDefinition/DocumentReference" ]
     ] ;
     fhir:type [
       fhir:code [ fhir:v "DocumentReference" ]
     ] ;
     fhir:name [ fhir:v "Document" ]
  ] ) . # 

