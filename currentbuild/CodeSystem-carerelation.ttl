  fhir:Resource.id [ fhir:value "carerelation"]; # 
  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ];
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>This code system <code>urn:AuditEventHL7Norway/CodeSystem/carerelation</code> defines the following codes:</p><table class=\"codes\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td style=\"white-space:nowrap\">HENV_BEH<a name=\"carerelation-HENV_BEH\"> </a></td><td>Henvendelse fra pasientens behandler</td><td>Henvendelse fra pasientens behandler.</td></tr><tr><td style=\"white-space:nowrap\">HENV_PAA<a name=\"carerelation-HENV_PAA\"> </a></td><td>Henvendelse fra pasientens pårørende</td><td>Henvendelse fra pasientens pårørende.</td></tr><tr><td style=\"white-space:nowrap\">MELDT<a name=\"carerelation-MELDT\"> </a></td><td>Meldt pasient</td><td>Meldt pasient (for eksempel fra legevakta eller ambulansen).</td></tr><tr><td style=\"white-space:nowrap\">BLAALYS<a name=\"carerelation-BLAALYS\"> </a></td><td>Blålys</td><td>Bruk av blålys - akutt helsehjelp</td></tr><tr><td style=\"white-space:nowrap\">EKSTSVAR<a name=\"carerelation-EKSTSVAR\"> </a></td><td>Eksternt prøvesvar/notat til vurdering</td><td>Det er behov for å se på et eksternt prøvesvar eller notat som har kommet inn på pasienten</td></tr><tr><td style=\"white-space:nowrap\">KVAL<a name=\"carerelation-KVAL\"> </a></td><td>Internkontroll/Kvalitetssikring</td><td>Noen ansatte har som oppgave å kontrollere koder og andre registreringer i DIPS, kanskje også se på hvordan det registreres/dokumenteres m.m uten at brukeren deltar i behandling av pasient.   Da kan denne beslutningsmalen brukes.</td></tr><tr><td style=\"white-space:nowrap\">OPRPLAN<a name=\"carerelation-OPRPLAN\"> </a></td><td>Pasienten finnes på operasjonsoversikten</td><td>Pasienten finnes på operasjonsoversikten i DIPS</td></tr><tr><td style=\"white-space:nowrap\">KONSSERIE<a name=\"carerelation-KONSSERIE\"> </a></td><td>Åpen konsultasjonsserie</td><td>Åpen konsultasjonsserie</td></tr><tr><td style=\"white-space:nowrap\">LEDSBEL<a name=\"carerelation-LEDSBEL\"> </a></td><td>Inneliggende ledsager</td><td>Ledsageren er inneliggende.</td></tr><tr><td style=\"white-space:nowrap\">VURDHENV<a name=\"carerelation-VURDHENV\"> </a></td><td>Vurdert henvisning</td><td>Henvisning som er vurdert</td></tr><tr><td style=\"white-space:nowrap\">ITSYSARB<a name=\"carerelation-ITSYSARB\"> </a></td><td>IT-Systemarbeid</td><td>IT systemarbeid er en besluttningsmal som kan benyttes for å gi tilgang til journaldata når it-personell (på sykehuset / eller personell fra DIPS ASA), må gjøre systemarbeid - feilretting o.l. - på journaldataene.</td></tr><tr><td style=\"white-space:nowrap\">TILSYN<a name=\"carerelation-TILSYN\"> </a></td><td>Tilsyn på annen avdeling.</td><td>&quot;Tilsyn på annen avdeling&quot; kan benyttes når en behandler bes om å foreta et tilsyn på en annen avdeling, og behandleren av den grunn ikke har ordinær tilgang til journalen.  Det kan angis hvilken rekvirent som har bedt om at tilsyn skal foretas.</td></tr><tr><td style=\"white-space:nowrap\">ARBFLYT<a name=\"carerelation-ARBFLYT\"> </a></td><td>Oppgave i arbeidsflyt</td><td>Beslutning som slår til dersom det finnes en ikke utført oppgave i arbeidsflyt.  Gjelder alle oppgavetyper.</td></tr><tr><td style=\"white-space:nowrap\">BEHANDLER<a name=\"carerelation-BEHANDLER\"> </a></td><td>Bruker har behandlingsansvar for pasienten</td><td>Brukeren er behandler for pasienten. Eksempler på hva som gjør at malen slår til er:\na) Bruker er registrert som ansvarlig behandler på poliklinisk besøk.\nb) Bruker er registrert som behandler på planlagt kontakt.\nc) Bruker er registrert som ansvarlig lege på et postopphold. \nd) Bruker er registrert som ansvarlig behandler for omsorgsserie i psykiatrien.\ne) Bruker er registrert som koterapeut til en poliklinisk konsultasjon (gjelder psykiatri).\nf) Bruker er registrert som deltaker (ressurs) i en planlagt aktivitet i pasientens timebok.</td></tr><tr><td style=\"white-space:nowrap\">INFOANSV<a name=\"carerelation-INFOANSV\"> </a></td><td>Bruker er informasjonsansvarlig for pasienten</td><td>Brukeren er informasjonsansvarlig for pasienten.</td></tr><tr><td style=\"white-space:nowrap\">JOURANSV<a name=\"carerelation-JOURANSV\"> </a></td><td>Bruker er journalansvarlig for pasienten</td><td>Brukeren er journalansvarlig for pasienten.</td></tr><tr><td style=\"white-space:nowrap\">PASANSV<a name=\"carerelation-PASANSV\"> </a></td><td>Bruker er koordinator for pasienten</td><td>Brukeren er koordinator for pasienten.</td></tr><tr><td style=\"white-space:nowrap\">HENVISNING<a name=\"carerelation-HENVISNING\"> </a></td><td>Henvisning til vurdering</td><td>Henvisning som enda ikke er vurdert.</td></tr><tr><td style=\"white-space:nowrap\">BELEGG<a name=\"carerelation-BELEGG\"> </a></td><td>Inneliggende pasient</td><td>Pasienten er inneliggende.</td></tr><tr><td style=\"white-space:nowrap\">PLANOPP<a name=\"carerelation-PLANOPP\"> </a></td><td>Planlagt oppmøte</td><td>Planlagt oppmøte for pasienten.</td></tr><tr><td style=\"white-space:nowrap\">POLBESOK<a name=\"carerelation-POLBESOK\"> </a></td><td>Poliklinisk besøk</td><td>Poliklinisk konsultasjon.</td></tr><tr><td style=\"white-space:nowrap\">TILSYN2<a name=\"carerelation-TILSYN2\"> </a></td><td>Tilsyn med helsepersonellets virksomhet</td><td>Tilsyn med helsepersonellets virksomhet.</td></tr><tr><td style=\"white-space:nowrap\">INNSYN<a name=\"carerelation-INNSYN\"> </a></td><td>Pasientinnsyn</td><td>Pasientens innsyn i egen journal.</td></tr><tr><td style=\"white-space:nowrap\">OFFBEST<a name=\"carerelation-OFFBEST\"> </a></td><td>Bestilling av dokumenter fra offentlige og juridiske instanser og forsikringselskap</td><td>Bestilling av dokumenter fra offentlige og juridiske instanser og forsikringselskap.</td></tr><tr><td style=\"white-space:nowrap\">HENV_PAS<a name=\"carerelation-HENV_PAS\"> </a></td><td>Henvendelse fra pasienten</td><td>Henvendelse fra pasienten selv.</td></tr><tr><td style=\"white-space:nowrap\">HENVPER<a name=\"carerelation-HENVPER\"> </a></td><td>Åpen henvisningsperiode</td><td>Åpen henvisningsperiode.</td></tr><tr><td style=\"white-space:nowrap\">PLANKONT<a name=\"carerelation-PLANKONT\"> </a></td><td>Ventende pasient</td><td>Pasienten har en planlagt kontakt som ikke er avsluttet.</td></tr><tr><td style=\"white-space:nowrap\">PRIMKONT<a name=\"carerelation-PRIMKONT\"> </a></td><td>Bruker er pasientens primærkontakt</td><td>Bruker er pasientens primærkontakt.</td></tr><tr><td style=\"white-space:nowrap\">DELBEHAN<a name=\"carerelation-DELBEHAN\"> </a></td><td>Deltar i behandlingen av pasienten</td><td>Deltar i behandlingen av pasienten.</td></tr><tr><td style=\"white-space:nowrap\">TILSYN3<a name=\"carerelation-TILSYN3\"> </a></td><td>Statlig tilsyn</td><td>Statlig tilsyn er forankret i  Helsetilsynsloven, Spesialisthelsetjenesteloven §6-2 og Pasientjournalloven §26.</td></tr><tr><td style=\"white-space:nowrap\">HHJELANPAS<a name=\"carerelation-HHJELANPAS\"> </a></td><td>Yte helsehjelp til annen pasient</td><td>&quot;Yte helsehjelp til annen pasient&quot; kan benyttes for å gi tilgang til pasientopplysninger på en pasient for å yte helsehjelp til annen pasient, jf. helsepersonelloven §25 b.</td></tr><tr><td style=\"white-space:nowrap\">NYPAS<a name=\"carerelation-NYPAS\"> </a></td><td>Pasientadministrasjon</td><td>Pasientadministrasjon, f.eks registrering av ny pasient</td></tr><tr><td style=\"white-space:nowrap\">ROLPAS<a name=\"carerelation-ROLPAS\"> </a></td><td>Bruker har rolle overfor pasient</td><td>Bruker har rolle overfor pasient</td></tr><tr><td style=\"white-space:nowrap\">EGENLAER<a name=\"carerelation-EGENLAER\"> </a></td><td>Egen læring/kvalitetssikring av gitt behandling</td><td>Begrunnelse forankret i Helsepersonellovens §29 c</td></tr></table></div>"
  ]; # 
