       fhir:name [ fhir:v "AuditEventEncounterExtension" ] ;
       fhir:description [ fhir:v "Extension that extends FHIR AuditEvent R4 with Encounter reference which was introduced in FHIR AuditEvent R5" ] ;
       fhir:example [ fhir:v "false"^^xsd:boolean ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
