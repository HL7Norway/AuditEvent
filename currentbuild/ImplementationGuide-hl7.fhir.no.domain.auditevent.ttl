       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.no/fhir/StructureDefinition/no-basis-propertyinformation> ;
         fhir:reference [ fhir:v "StructureDefinition/no-basis-propertyinformation" ]
       ] ;
       fhir:name [ fhir:v "no-basis-propertyinformation" ] ;
       fhir:description [ fhir:v "This basis extension describes information identifying norwegian real property." ] ;
       fhir:example [ fhir:v "false"^^xsd:boolean ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
