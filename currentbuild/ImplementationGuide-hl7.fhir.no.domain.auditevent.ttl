       ] ;
       fhir:name [ fhir:v "AuditEventCareRelationMetaData" ] ;
       fhir:description [ fhir:v "This extension is used to carry attributes from Norwegian Trust Framework (Nasjonalt tillitsrammeverk) which there exists no natural element for." ] ;
       fhir:example [ fhir:v "false"^^xsd:boolean ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
