       fhir:description [ fhir:v "Extension that extends FHIR AuditEvent R4 with en Patient reference which was introduced in FHIR AuditEvent R5" ] ;
       fhir:example [ fhir:v "false"^^xsd:boolean ]
     ] [
       fhir:extension ( [
