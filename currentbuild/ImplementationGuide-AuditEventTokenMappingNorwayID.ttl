       fhir:example [
         fhir:v "urn:AuditEventTokenMappingNorway/StructureDefinition/AuditEventNorwayTokenProfile"^^xsd:anyURI ;
         fhir:link <urn:AuditEventTokenMappingNorway/urn:AuditEventTokenMappingNorway/StructureDefinition/AuditEventNorwayTokenProfile>
