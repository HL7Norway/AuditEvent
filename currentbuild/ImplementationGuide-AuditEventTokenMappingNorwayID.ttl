       fhir:reference [
         fhir:link <urn:AuditEventTokenMappingNorway/AuditEvent/AuditEventNorwayTokenInstance2> ;
         fhir:reference [ fhir:v "AuditEvent/AuditEventNorwayTokenInstance2" ]
       ] ;
       fhir:name [ fhir:v "Healthcare professionals in the enterprise request access to the document" ] ;
       fhir:description [ fhir:v "In this example, an anesthesiologist who formally belongs to Rikshospitalet is preparing to administer anesthesia to a patient who is in for an eye operation at Ullevål Hospital, and the anesthesiologist therefore needs access to read documents from previous caregivers in other enterprises to find out which active substances were used during previous anesthesia that the patient reports caused allergic reactions" ] ;
       fhir:example [
         fhir:v "urn:AuditEventTokenMappingNorway/StructureDefinition/AuditEventNorwayTokenProfile"^^xsd:anyURI ;
