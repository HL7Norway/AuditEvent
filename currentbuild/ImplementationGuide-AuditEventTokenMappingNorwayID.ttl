       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [ fhir:v "StructureDefinition:resource" ]
       ] ) ;
       fhir:reference [
         fhir:link <urn:AuditEventTokenMappingNorway/StructureDefinition/AuditEventNorwayTokenProfile> ;
         fhir:reference [ fhir:v "StructureDefinition/AuditEventNorwayTokenProfile" ]
       ] ;
       fhir:name [ fhir:v "National profile for AuditEvent for security token mapping" ] ;
       fhir:description [ fhir:v "This profile should be used in all use cases where the request to an API involves a security token (JWT/SAML). The profile describes how the attributes / claims of a \ntoken must be mapped into elements / fields of an AuditEvent if they are present." ] ;
       fhir:example [ fhir:v "false"^^xsd:boolean ]
     ] ) ;
